<html>
<head>
<title>Unicate Gaming RPG - Launcher</title>
<HTA:APPLICATION
  ID="UnicateGamingLauncher"
  APPLICATIONNAME="Unicate Gaming RPG"
  BORDER="none"
  BORDERSTYLE="normal"
  CAPTION="no"
  CONTEXTMENU="no"
  INNERBORDER="no"
  MAXIMIZEBUTTON="no"
  MINIMIZEBUTTON="no"
  SHOWINTASKBAR="yes"
  SINGLEINSTANCE="yes"
  SYSMENU="no"
  VERSION="3.0.0"
  WINDOWSTATE="normal"
/>
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    overflow: hidden;
    background: #050a15;
    font-family: 'Segoe UI', 'Rajdhani', Tahoma, sans-serif;
    color: #e2e8f0;
    user-select: none;
    cursor: default;
  }

  .launcher {
    width: 1100px;
    height: 700px;
    display: flex;
    flex-direction: column;
    background: #050a15;
    position: relative;
    overflow: hidden;
  }

  /* === ANIMATED BACKGROUND === */
  .bg-layer {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 0;
  }
  .bg-grad {
    background: linear-gradient(135deg, #050a15 0%, #0a1628 30%, #0f1d35 55%, #0a1628 80%, #050a15 100%);
    background-size: 300% 300%;
    animation: gradShift 20s ease infinite;
  }
  @keyframes gradShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .bg-grid {
    background-image:
      linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    z-index: 1;
  }

  .bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: 1;
    pointer-events: none;
  }
  .orb1 {
    width: 350px; height: 350px;
    background: rgba(59,130,246,0.1);
    top: -80px; left: -80px;
    animation: orbF1 10s ease-in-out infinite;
  }
  .orb2 {
    width: 280px; height: 280px;
    background: rgba(30,64,175,0.08);
    bottom: -40px; right: 150px;
    animation: orbF2 13s ease-in-out infinite;
  }
  .orb3 {
    width: 200px; height: 200px;
    background: rgba(96,165,250,0.06);
    top: 300px; right: -30px;
    animation: orbF3 11s ease-in-out infinite;
  }
  @keyframes orbF1 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(30px,25px)} }
  @keyframes orbF2 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-25px,-15px)} }
  @keyframes orbF3 { 0%,100%{transform:translate(0,0)} 50%{transform:translate(-15px,25px)} }

  /* === SCANLINE EFFECT === */
  .scanline {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(59,130,246,0.15), transparent);
    z-index: 2;
    animation: scanMove 6s linear infinite;
  }
  @keyframes scanMove {
    0% { top: 0; }
    100% { top: 100%; }
  }

  /* === TOP BAR === */
  .topbar {
    height: 50px;
    background: rgba(8,12,22,0.9);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px;
    border-bottom: 1px solid rgba(59,130,246,0.15);
    flex-shrink: 0;
    z-index: 10;
    position: relative;
  }
  .topbar:after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(59,130,246,0.4), transparent);
  }
  .topbar-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .logo-img-small {
    width: 30px; height: 30px;
    object-fit: contain;
  }
  .logo-text-small {
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 3px;
    color: #60a5fa;
  }
  .logo-text-white {
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 3px;
    color: #e2e8f0;
  }
  .ver-badge {
    font-size: 9px;
    color: #475569;
    padding: 2px 8px;
    background: rgba(59,130,246,0.08);
    border: 1px solid rgba(59,130,246,0.15);
    border-radius: 10px;
  }
  .topbar-right {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .online-indicator {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    background: rgba(34,197,94,0.08);
    border: 1px solid rgba(34,197,94,0.2);
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    color: #22c55e;
    margin-right: 12px;
  }
  .online-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #22c55e;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%,100%{ opacity:1; box-shadow:0 0 0 0 rgba(34,197,94,0.4) }
    50%{ opacity:0.7; box-shadow:0 0 0 4px rgba(34,197,94,0) }
  }
  .win-btn {
    width: 36px; height: 36px;
    background: transparent;
    border: none;
    color: #64748b;
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    border-radius: 4px;
    font-family: 'Segoe UI', sans-serif;
  }
  .win-btn:hover { background: rgba(59,130,246,0.1); color: #e2e8f0; }
  .win-btn-close:hover { background: rgba(239,68,68,0.2); color: #ef4444; }

  /* === MAIN CONTENT === */
  .content {
    flex: 1;
    display: flex;
    overflow: hidden;
    position: relative;
    z-index: 5;
  }

  /* === LEFT SIDEBAR === */
  .sidebar {
    width: 260px;
    background: rgba(8,12,22,0.75);
    border-right: 1px solid rgba(59,130,246,0.08);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    position: relative;
  }
  .sidebar:after {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, rgba(59,130,246,0.2), transparent, rgba(59,130,246,0.1));
  }

  /* Server Card */
  .server-card {
    margin: 16px;
    padding: 14px;
    background: linear-gradient(135deg, rgba(30,64,175,0.12), rgba(59,130,246,0.04));
    border: 1px solid rgba(59,130,246,0.18);
    border-radius: 12px;
    position: relative;
    overflow: hidden;
  }
  .server-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, #3b82f6, #60a5fa, #3b82f6);
    animation: shimmer 3s infinite;
  }
  @keyframes shimmer { 0%{opacity:0.5} 50%{opacity:1} 100%{opacity:0.5} }

  .sc-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  .sc-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, #1e40af, #3b82f6);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(59,130,246,0.25);
    overflow: hidden;
  }
  .sc-icon img {
    width: 32px; height: 32px;
    object-fit: contain;
  }
  .sc-info h3 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #e2e8f0;
  }
  .sc-info p {
    font-size: 10px;
    color: #64748b;
    margin-top: 1px;
  }

  .sc-stats {
    display: flex;
    gap: 8px;
  }
  .sc-stat {
    flex: 1;
    padding: 7px;
    background: rgba(5,10,21,0.5);
    border: 1px solid rgba(59,130,246,0.1);
    border-radius: 8px;
    text-align: center;
  }
  .sc-stat-label {
    font-size: 8px;
    color: #475569;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 700;
  }
  .sc-stat-val {
    font-size: 13px;
    font-weight: 700;
    color: #60a5fa;
    margin-top: 2px;
  }
  .sc-stat-val.green { color: #22c55e; }

  /* Sidebar Nav */
  .sidebar-nav {
    padding: 8px 16px;
  }
  .nav-title {
    font-size: 9px;
    font-weight: 700;
    color: #334155;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 12px 0 6px;
  }
  .nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.15s;
    margin: 1px 0;
  }
  .nav-item:hover {
    background: rgba(59,130,246,0.08);
  }
  .nav-item.active {
    background: rgba(59,130,246,0.12);
    border: 1px solid rgba(59,130,246,0.15);
  }
  .nav-icon {
    width: 30px; height: 30px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    flex-shrink: 0;
  }
  .nav-icon.blue { background: rgba(59,130,246,0.15); color: #60a5fa; }
  .nav-icon.purple { background: rgba(139,92,246,0.15); color: #a78bfa; }
  .nav-icon.green { background: rgba(34,197,94,0.15); color: #22c55e; }
  .nav-icon.orange { background: rgba(245,158,11,0.15); color: #f59e0b; }
  .nav-icon.red { background: rgba(239,68,68,0.15); color: #ef4444; }
  .nav-text-main {
    font-size: 12px;
    font-weight: 600;
    color: #e2e8f0;
  }
  .nav-text-sub {
    font-size: 9px;
    color: #475569;
  }

  /* Sidebar Bottom */
  .sidebar-bottom {
    margin-top: auto;
    padding: 12px 16px;
    border-top: 1px solid rgba(59,130,246,0.08);
  }
  .gta-path-label {
    font-size: 8px;
    color: #475569;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .gta-path-box {
    padding: 7px 10px;
    background: rgba(5,10,21,0.5);
    border: 1px solid rgba(59,130,246,0.1);
    border-radius: 6px;
    font-size: 9px;
    color: #64748b;
    word-break: break-all;
    max-height: 28px;
    overflow: hidden;
    font-family: Consolas, monospace;
    margin-bottom: 6px;
  }
  .browse-btn {
    width: 100%;
    padding: 6px;
    background: rgba(59,130,246,0.1);
    border: 1px solid rgba(59,130,246,0.2);
    border-radius: 6px;
    color: #60a5fa;
    font-size: 10px;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-align: center;
    transition: all 0.15s;
  }
  .browse-btn:hover {
    background: rgba(59,130,246,0.2);
    border-color: rgba(59,130,246,0.4);
    color: #e2e8f0;
  }

  /* === MAIN AREA === */
  .main-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  /* Hero Section */
  .hero {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 30px 40px;
  }
  .hero-inner {
    display: flex;
    align-items: center;
    gap: 50px;
    max-width: 780px;
  }

  /* Logo with rotating ring */
  .logo-area {
    flex-shrink: 0;
    position: relative;
    width: 180px;
    height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .logo-ring1 {
    position: absolute;
    top: -8px; left: -8px;
    width: 196px; height: 196px;
    border: 2px solid rgba(59,130,246,0.2);
    border-radius: 50%;
    animation: ringRot 20s linear infinite;
  }
  .logo-ring1::after {
    content: '';
    position: absolute;
    top: -3px; left: 50%;
    width: 6px; height: 6px;
    background: #3b82f6;
    border-radius: 50%;
    box-shadow: 0 0 10px #3b82f6;
  }
  @keyframes ringRot { 0%{transform:rotate(0)} 100%{transform:rotate(360deg)} }
  .logo-ring2 {
    position: absolute;
    top: -18px; left: -18px;
    width: 216px; height: 216px;
    border: 1px solid rgba(59,130,246,0.07);
    border-radius: 50%;
    animation: ringRot 30s linear infinite reverse;
  }
  .logo-glow {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%,-50%);
    width: 160px; height: 160px;
    background: radial-gradient(circle, rgba(59,130,246,0.18), transparent 70%);
    border-radius: 50%;
  }
  .logo-main {
    width: 140px; height: 140px;
    object-fit: contain;
    position: relative;
    z-index: 2;
    filter: drop-shadow(0 0 25px rgba(59,130,246,0.3));
  }

  /* Hero Info */
  .hero-info {
    flex: 1;
  }
  .hero-title {
    font-size: 38px;
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 4px;
  }
  .hero-title-grad {
    background: linear-gradient(135deg, #93c5fd, #3b82f6, #1d4ed8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: #3b82f6;
  }
  .hero-subtitle {
    font-size: 16px;
    font-weight: 600;
    color: #3b82f6;
    letter-spacing: 6px;
    margin-bottom: 16px;
  }
  .hero-desc {
    font-size: 12px;
    color: #64748b;
    line-height: 1.7;
    margin-bottom: 20px;
    max-width: 380px;
  }

  /* Feature Pills */
  .pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 22px;
  }
  .pill {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 5px 12px;
    background: rgba(59,130,246,0.08);
    border: 1px solid rgba(59,130,246,0.15);
    border-radius: 20px;
    font-size: 10px;
    font-weight: 600;
    color: #94a3b8;
  }
  .pill strong { color: #60a5fa; }

  /* Connect Section */
  .connect-row {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .connect-btn {
    position: relative;
    width: 220px;
    height: 52px;
    background: linear-gradient(135deg, #3b82f6, #2563eb, #1d4ed8);
    border: none;
    border-radius: 12px;
    color: #fff;
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 4px;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.25s;
    box-shadow: 0 4px 20px rgba(59,130,246,0.3), 0 0 0 1px rgba(96,165,250,0.2);
  }
  .connect-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(59,130,246,0.5), 0 0 0 1px rgba(96,165,250,0.4);
  }
  .connect-btn:active { transform: translateY(0); }
  .connect-btn.connecting {
    background: linear-gradient(135deg, #1e40af, #1e3a8a);
    letter-spacing: 3px;
  }
  .connect-btn::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);
    animation: btnShine 3s infinite;
  }
  @keyframes btnShine { 0%{left:-100%} 50%,100%{left:100%} }

  .ip-box {
    padding: 10px 16px;
    background: rgba(5,10,21,0.5);
    border: 1px solid rgba(59,130,246,0.15);
    border-radius: 10px;
  }
  .ip-label {
    font-size: 8px;
    color: #475569;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 700;
  }
  .ip-value {
    font-size: 12px;
    font-weight: 600;
    color: #60a5fa;
    letter-spacing: 1px;
    font-family: Consolas, monospace;
  }

  /* === NEWS PANEL (floating) === */
  .news-panel {
    position: absolute;
    right: 16px;
    top: 16px;
    width: 270px;
    background: rgba(8,12,22,0.85);
    border: 1px solid rgba(59,130,246,0.1);
    border-radius: 14px;
    overflow: hidden;
    z-index: 15;
  }
  .news-header {
    padding: 10px 14px;
    background: linear-gradient(135deg, rgba(30,64,175,0.18), rgba(59,130,246,0.08));
    border-bottom: 1px solid rgba(59,130,246,0.1);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .news-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    color: #60a5fa;
  }
  .news-badge {
    padding: 2px 8px;
    background: rgba(59,130,246,0.2);
    border-radius: 10px;
    font-size: 8px;
    font-weight: 700;
    color: #60a5fa;
  }
  .news-body { padding: 6px 10px; }
  .news-item {
    padding: 8px 6px;
    border-bottom: 1px solid rgba(59,130,246,0.06);
    display: flex;
    gap: 8px;
  }
  .news-item:last-child { border-bottom: none; }
  .news-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 4px;
  }
  .news-item-title {
    font-size: 11px;
    font-weight: 700;
    color: #e2e8f0;
  }
  .news-item-desc {
    font-size: 9px;
    color: #475569;
    margin-top: 1px;
    line-height: 1.4;
  }

  /* === BOTTOM BAR === */
  .bottombar {
    height: 48px;
    background: rgba(8,12,22,0.9);
    border-top: 1px solid rgba(59,130,246,0.1);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    z-index: 10;
    position: relative;
  }
  .bottombar::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(59,130,246,0.3), transparent);
  }
  .bottom-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .bottom-stat {
    font-size: 10px;
    color: #475569;
  }
  .bottom-stat-val {
    font-weight: 700;
    color: #94a3b8;
  }
  .bottom-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .bottom-link {
    font-size: 10px;
    font-weight: 600;
    color: #475569;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 0.15s;
  }
  .bottom-link:hover { color: #60a5fa; }
  .cef-badge {
    padding: 3px 8px;
    background: rgba(59,130,246,0.1);
    border: 1px solid rgba(59,130,246,0.2);
    border-radius: 6px;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 1px;
    color: #60a5fa;
  }

  /* === ERROR OVERLAY === */
  .error-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(5,10,21,0.95);
    z-index: 30;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px;
  }
  .error-overlay.show { display: flex; }
  .error-icon-box {
    width: 60px; height: 60px;
    border-radius: 50%;
    background: rgba(239,68,68,0.1);
    border: 2px solid rgba(239,68,68,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    margin-bottom: 14px;
  }
  .error-title {
    font-size: 18px;
    font-weight: 700;
    color: #ef4444;
    margin-bottom: 8px;
  }
  .error-msg {
    font-size: 13px;
    color: #94a3b8;
    text-align: center;
    max-width: 400px;
    line-height: 1.6;
  }
  .error-close-btn {
    margin-top: 18px;
    padding: 8px 36px;
    background: rgba(59,130,246,0.15);
    border: 1px solid rgba(59,130,246,0.3);
    border-radius: 8px;
    color: #60a5fa;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 2px;
    transition: all 0.15s;
  }
  .error-close-btn:hover {
    background: rgba(59,130,246,0.25);
    color: #e2e8f0;
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 3px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(59,130,246,0.2); border-radius: 3px; }
</style>
</head>
<body>

<div class="launcher" id="mainWindow">

  <!-- Background layers -->
  <div class="bg-layer bg-grad"></div>
  <div class="bg-layer bg-grid"></div>
  <div class="bg-orb orb1"></div>
  <div class="bg-orb orb2"></div>
  <div class="bg-orb orb3"></div>
  <div class="scanline"></div>

  <!-- TOP BAR -->
  <div class="topbar" id="topbar">
    <div class="topbar-left">
      <img src="ug_logo.png" class="logo-img-small" onerror="this.style.display='none'">
      <span class="logo-text-small">UNICATE</span>
      <span class="logo-text-white">GAMING</span>
      <span class="ver-badge">v3.0</span>
    </div>
    <div class="topbar-right">
      <div class="online-indicator">
        <div class="online-dot" id="onlineDot"></div>
        <span id="topPlayerCount">--</span>
      </div>
      <button class="win-btn" onclick="minimizeWindow()" title="Minimize">&#8212;</button>
      <button class="win-btn win-btn-close" onclick="closeWindow()" title="Close">&#10005;</button>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <div class="content">

    <!-- LEFT SIDEBAR -->
    <div class="sidebar">

      <!-- Server Card -->
      <div class="server-card">
        <div class="sc-header">
          <div class="sc-icon">
            <img src="ug_logo.png" style="width:28px;height:28px;object-fit:contain" onerror="this.parentElement.innerHTML='UG'">
          </div>
          <div class="sc-info">
            <h3>UNICATE GAMING</h3>
            <p>RPG Server</p>
          </div>
        </div>
        <div class="sc-stats">
          <div class="sc-stat">
            <div class="sc-stat-label">STATUS</div>
            <div class="sc-stat-val green" id="statStatus">...</div>
          </div>
          <div class="sc-stat">
            <div class="sc-stat-label">IGRACI</div>
            <div class="sc-stat-val" id="statPlayers">--</div>
          </div>
          <div class="sc-stat">
            <div class="sc-stat-label">MODE</div>
            <div class="sc-stat-val" id="statMode">RPG</div>
          </div>
        </div>
      </div>

      <!-- Sidebar Nav -->
      <div class="sidebar-nav">
        <div class="nav-title">NAVIGACIJA</div>

        <div class="nav-item active" onclick="selectNav(this)">
          <div class="nav-icon blue">&#9654;</div>
          <div>
            <div class="nav-text-main">Igraj</div>
            <div class="nav-text-sub">Konektuj se na server</div>
          </div>
        </div>

        <div class="nav-item" onclick="openLink('https://discord.gg/unicategaming')">
          <div class="nav-icon purple">&#9827;</div>
          <div>
            <div class="nav-text-main">Discord</div>
            <div class="nav-text-sub">Pridruzi se zajednici</div>
          </div>
        </div>

        <div class="nav-item" onclick="openLink('https://ug-ogc.com')">
          <div class="nav-icon green">&#9733;</div>
          <div>
            <div class="nav-text-main">Website</div>
            <div class="nav-text-sub">ug-ogc.com</div>
          </div>
        </div>

        <div class="nav-item" onclick="openLink('https://ug-ogc.com/forum')">
          <div class="nav-icon orange">&#9998;</div>
          <div>
            <div class="nav-text-main">Forum</div>
            <div class="nav-text-sub">Diskusije i vijesti</div>
          </div>
        </div>

        <div class="nav-item" onclick="installCEF()">
          <div class="nav-icon red">&#9881;</div>
          <div>
            <div class="nav-text-main">CEF Plugin</div>
            <div class="nav-text-sub" id="cefNavStatus">Provjeri instalaciju</div>
          </div>
        </div>
      </div>

      <!-- Sidebar Bottom -->
      <div class="sidebar-bottom">
        <div class="gta-path-label">GTA San Andreas Path</div>
        <div class="gta-path-box" id="gtaPathDisplay">Pretrazujem...</div>
        <button class="browse-btn" onclick="browseGTA()">Browse GTA SA</button>
      </div>
    </div>

    <!-- MAIN AREA -->
    <div class="main-area">

      <!-- HERO -->
      <div class="hero">
        <div class="hero-inner">
          <div class="logo-area">
            <div class="logo-ring1"></div>
            <div class="logo-ring2"></div>
            <div class="logo-glow"></div>
            <img src="ug_logo.png" class="logo-main" onerror="this.style.display='none'">
          </div>
          <div class="hero-info">
            <div class="hero-title">
              <span class="hero-title-grad">UNICATE</span><br>
              GAMING RPG
            </div>
            <div class="hero-subtitle">ONLINE RPG</div>
            <div class="hero-desc">
              Dobrodosli na Unicate Gaming RPG server! Koristite launcher da se konektujete direktno na server.
              CEF plugin omogucava moderan UI za Tablet, Inventar i Laptop.
            </div>
            <div class="pills">
              <span class="pill"><strong>CEF</strong> Tablet UI</span>
              <span class="pill"><strong>CEF</strong> Inventar</span>
              <span class="pill"><strong>CEF</strong> Laptop</span>
              <span class="pill"><strong>24/7</strong> Online</span>
              <span class="pill"><strong>RPG</strong> Gamemode</span>
            </div>
            <div class="connect-row">
              <button class="connect-btn" id="connectBtn" onclick="connectToServer()">CONNECT</button>
              <div class="ip-box">
                <div class="ip-label">SERVER IP</div>
                <div class="ip-value">135.125.156.197:7777</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- NEWS PANEL -->
      <div class="news-panel">
        <div class="news-header">
          <span class="news-title">NOVOSTI</span>
          <span class="news-badge">NOVO</span>
        </div>
        <div class="news-body">
          <div class="news-item">
            <div class="news-dot" style="background:#3b82f6"></div>
            <div>
              <div class="news-item-title">CEF Launcher Update</div>
              <div class="news-item-desc">Novi launcher sa automatskom konekcijom na server i CEF plugin provjerom.</div>
            </div>
          </div>
          <div class="news-item">
            <div class="news-dot" style="background:#8b5cf6"></div>
            <div>
              <div class="news-item-title">CEF Tablet & Inventar</div>
              <div class="news-item-desc">Koristite /tablet i /inventory za moderan UI u igri. CEF plugin potreban!</div>
            </div>
          </div>
          <div class="news-item">
            <div class="news-dot" style="background:#22c55e"></div>
            <div>
              <div class="news-item-title">Novi Server IP</div>
              <div class="news-item-desc">Server je sad na 135.125.156.197:7777. Launcher vas automatski konektuje!</div>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /main-area -->
  </div><!-- /content -->

  <!-- BOTTOM BAR -->
  <div class="bottombar">
    <div class="bottom-left">
      <span class="bottom-stat">Server: <span class="bottom-stat-val" id="bottomServer">135.125.156.197:7777</span></span>
      <span class="bottom-stat">CEF: <span class="bottom-stat-val" id="bottomCEFVal">--</span></span>
      <span class="bottom-stat">Launcher: <span class="bottom-stat-val">v3.0</span></span>
    </div>
    <div class="bottom-right">
      <span class="bottom-link" onclick="openLink('https://ug-ogc.com')">Website</span>
      <span class="bottom-link" onclick="openLink('https://discord.gg/unicategaming')">Discord</span>
      <span class="bottom-link" onclick="openLink('https://ug-ogc.com/forum')">Forum</span>
      <span class="cef-badge" id="cefBadge">CEF: --</span>
    </div>
  </div>

  <!-- ERROR OVERLAY -->
  <div class="error-overlay" id="errorOverlay">
    <div class="error-icon-box">!</div>
    <div class="error-title" id="errorTitle">Greska</div>
    <div class="error-msg" id="errorMsg">Doslo je do greske.</div>
    <button class="error-close-btn" onclick="hideError()">ZATVORI</button>
  </div>

</div><!-- /launcher -->

<script>
  // ============================================================
  //  UNICATE GAMING LAUNCHER v3.0 - IE/HTA Compatible
  //  Server: 135.125.156.197:7777
  // ============================================================

  var SERVER_IP = "135.125.156.197";
  var SERVER_PORT = "7777";

  // Resize window
  window.resizeTo(1100, 700);
  window.moveTo((screen.width - 1100) / 2, (screen.height - 700) / 2);

  // ============================================================
  //  DRAG WINDOW (IE-compatible - no .closest())
  // ============================================================
  var isDragging = false, dragX = 0, dragY = 0;

  document.getElementById('topbar').onmousedown = function(e) {
    // IE-compatible check: don't drag if clicking buttons
    var el = e.srcElement || e.target;
    if (el.tagName === 'BUTTON') return;
    isDragging = true;
    dragX = e.screenX - window.screenLeft;
    dragY = e.screenY - window.screenTop;
  };

  document.onmousemove = function(e) {
    if (isDragging) {
      window.moveTo(e.screenX - dragX, e.screenY - dragY);
    }
  };

  document.onmouseup = function() {
    isDragging = false;
  };

  // ============================================================
  //  WINDOW CONTROLS
  // ============================================================
  function minimizeWindow() { window.blur(); }
  function closeWindow() { window.close(); }

  // ============================================================
  //  FILE SYSTEM & SHELL
  // ============================================================
  var gtaPath = "";
  var fso, shell;

  try {
    fso = new ActiveXObject("Scripting.FileSystemObject");
    shell = new ActiveXObject("WScript.Shell");
  } catch(e) {
    // Fallback if ActiveX not available
  }

  // ============================================================
  //  FIND GTA SA
  // ============================================================
  function findGTASA() {
    if (!fso) {
      document.getElementById('gtaPathDisplay').innerHTML = '<span style="color:#f59e0b">ActiveX nije dostupan</span>';
      return;
    }

    // 1. Check registry for SA-MP path
    try {
      var sampPath = shell.RegRead("HKCU\\Software\\SAMP\\gta_sa_exe");
      if (sampPath && fso.FileExists(sampPath)) {
        gtaPath = fso.GetParentFolderName(sampPath);
        updateGTAPathDisplay();
        return;
      }
    } catch(e) {}

    // 2. Check common paths
    var paths = [
      "C:\\Program Files (x86)\\Rockstar Games\\GTA San Andreas",
      "C:\\Program Files\\Rockstar Games\\GTA San Andreas",
      "C:\\Games\\GTA San Andreas",
      "C:\\Games\\GTA SA",
      "D:\\Games\\GTA San Andreas",
      "D:\\GTA San Andreas",
      "D:\\Games\\GTA SA",
      "D:\\GTA SA",
      "D:\\Unicate Gaming",
      "E:\\GTA San Andreas",
      "E:\\GTA SA",
      "E:\\Games\\GTA San Andreas"
    ];

    for (var i = 0; i < paths.length; i++) {
      if (fso.FileExists(paths[i] + "\\gta_sa.exe")) {
        gtaPath = paths[i];
        updateGTAPathDisplay();
        return;
      }
    }

    // Not found
    gtaPath = "";
    document.getElementById('gtaPathDisplay').innerHTML = '<span style="color:#ef4444">GTA SA nije pronadjen!</span>';
  }

  function updateGTAPathDisplay() {
    if (gtaPath) {
      document.getElementById('gtaPathDisplay').innerHTML = '<span style="color:#22c55e">' + gtaPath + '</span>';
      checkCEFPlugin();
    }
  }

  // ============================================================
  //  BROWSE FOR GTA SA
  // ============================================================
  function browseGTA() {
    if (!fso) return;
    try {
      var shellApp = new ActiveXObject("Shell.Application");
      var folder = shellApp.BrowseForFolder(0, "Pronadji GTA San Andreas folder", 0);
      if (folder) {
        var path = folder.Self.Path;
        if (fso.FileExists(path + "\\gta_sa.exe")) {
          gtaPath = path;
          updateGTAPathDisplay();
        } else {
          showError("Greska", "gta_sa.exe nije pronadjen u tom folderu!\n\nIzaberi folder gdje je instaliran GTA San Andreas.");
        }
      }
    } catch(e) {}
  }

  // ============================================================
  //  CHECK CEF PLUGIN
  // ============================================================
  function checkCEFPlugin() {
    if (!gtaPath || !fso) { setCEFStatus(false); return; }
    var hasASI = fso.FileExists(gtaPath + "\\cef.asi");
    var hasFolder = fso.FolderExists(gtaPath + "\\CEF");
    setCEFStatus(hasASI && hasFolder);
  }

  function setCEFStatus(installed) {
    var text = installed ? "DA" : "NE";
    var color = installed ? "#22c55e" : "#f59e0b";

    if (document.getElementById('statStatus')) {
      // Already handled separately
    }
    document.getElementById('bottomCEFVal').innerHTML = '<span style="color:' + color + '">' + text + '</span>';
    document.getElementById('cefBadge').innerHTML = 'CEF: ' + text;
    document.getElementById('cefBadge').style.color = color;
    document.getElementById('cefBadge').style.borderColor = color;
    document.getElementById('cefNavStatus').innerHTML = installed ? 'Instaliran' : 'Nije instaliran';
  }

  // ============================================================
  //  INSTALL CEF PLUGIN (copy from launcher folder)
  // ============================================================
  function installCEF() {
    if (!gtaPath || !fso) {
      showError("Greska", "Prvo pronadji GTA San Andreas folder!");
      return;
    }

    var launcherDir = getLauncherDir();
    var cefSource = launcherDir + "\\cef_files";

    if (!fso.FolderExists(cefSource)) {
      showError("CEF Plugin", "CEF fajlovi nisu pronadjeni u launcher folderu.\n\nPreuzmi CEF plugin sa sajta i kopiraj u:\n" + cefSource);
      return;
    }

    try {
      // Copy cef.asi
      if (fso.FileExists(cefSource + "\\cef.asi")) {
        fso.CopyFile(cefSource + "\\cef.asi", gtaPath + "\\", true);
      }
      // Copy CEF folder
      if (fso.FolderExists(cefSource + "\\CEF")) {
        if (fso.FolderExists(gtaPath + "\\CEF")) {
          fso.DeleteFolder(gtaPath + "\\CEF", true);
        }
        fso.CopyFolder(cefSource + "\\CEF", gtaPath + "\\CEF", true);
      }

      checkCEFPlugin();
      alert("CEF Plugin uspjesno instaliran!");
    } catch(e) {
      showError("Greska", "Nije moguce instalirati CEF plugin!\n\n" + e.message);
    }
  }

  function getLauncherDir() {
    try {
      return fso.GetParentFolderName(document.location.pathname.replace(/^\//, '').replace(/\//g, '\\'));
    } catch(e) {
      return ".";
    }
  }

  // ============================================================
  //  CHECK SERVER STATUS (SA-MP Query via HTTP fallback)
  // ============================================================
  function checkServerStatus() {
    // Since HTA can't do UDP, we try HTTP status endpoint
    // If not available, assume server is online
    try {
      var xmlHttp = new ActiveXObject("MSXML2.XMLHTTP");
      xmlHttp.open("GET", "http://" + SERVER_IP + "/status.json", true);
      xmlHttp.onreadystatechange = function() {
        if (xmlHttp.readyState == 4) {
          try {
            var data = eval("(" + xmlHttp.responseText + ")");
            updateServerUI(data.online, data.players, data.max_players, data.gamemode);
          } catch(e) {
            // No status endpoint - assume online
            updateServerUI(true, 0, 200, "Unicate Gaming RPG");
          }
        }
      };
      xmlHttp.setTimeouts(5000, 5000, 5000, 5000);
      xmlHttp.send(null);
    } catch(e) {
      updateServerUI(true, 0, 200, "Unicate Gaming RPG");
    }
  }

  function updateServerUI(online, players, max, mode) {
    if (online) {
      document.getElementById('statStatus').innerHTML = '<span style="color:#22c55e">ONLINE</span>';
      document.getElementById('statPlayers').textContent = players + '/' + max;
      document.getElementById('statMode').textContent = mode || 'RPG';
      document.getElementById('topPlayerCount').textContent = players + '/' + max;
      document.getElementById('onlineDot').style.background = '#22c55e';
    } else {
      document.getElementById('statStatus').innerHTML = '<span style="color:#ef4444">OFF</span>';
      document.getElementById('statPlayers').textContent = '--';
      document.getElementById('statMode').textContent = '--';
      document.getElementById('topPlayerCount').textContent = 'OFFLINE';
      document.getElementById('onlineDot').style.background = '#ef4444';
    }
  }

  // ============================================================
  //  CONNECT TO SERVER
  // ============================================================
  function connectToServer() {
    var btn = document.getElementById('connectBtn');

    if (!gtaPath) {
      showError("Greska", "GTA San Andreas nije pronadjen!\n\nKlikni 'Browse GTA SA' u lijevom meniju da pronadjes gta_sa.exe na tvom racunaru.");
      return;
    }

    if (!fso.FileExists(gtaPath + "\\gta_sa.exe")) {
      showError("Greska", "gta_sa.exe nije pronadjen u:\n" + gtaPath + "\n\nIzaberi ispravni folder.");
      return;
    }

    if (!fso.FileExists(gtaPath + "\\samp.exe")) {
      showError("SA-MP nije instaliran", "samp.exe nije pronadjen u GTA folderu!\n\nMoras instalirati SA-MP client.\nPreuzmi ga sa sa-mp.com i instaliraj u GTA SA folder.");
      return;
    }

    // Start connecting
    btn.textContent = "POKRECEM...";
    btn.className = "connect-btn connecting";

    try {
      shell.CurrentDirectory = gtaPath;
      shell.Run('"' + gtaPath + '\\samp.exe" ' + SERVER_IP + ':' + SERVER_PORT, 1, false);

      setTimeout(function() {
        btn.textContent = "POKRENUTO!";
        setTimeout(function() {
          btn.textContent = "CONNECT";
          btn.className = "connect-btn";
        }, 3000);
      }, 2000);

    } catch(e) {
      btn.textContent = "CONNECT";
      btn.className = "connect-btn";
      showError("Greska", "Nije moguce pokrenuti igru!\n\n" + e.message);
    }
  }

  // ============================================================
  //  NAVIGATION
  // ============================================================
  function selectNav(el) {
    var items = document.getElementsByTagName('div');
    for (var i = 0; i < items.length; i++) {
      if (items[i].className === 'nav-item active') {
        items[i].className = 'nav-item';
      }
    }
    el.className = 'nav-item active';
  }

  function openLink(url) {
    try {
      shell.Run(url, 1, false);
    } catch(e) {
      window.open(url);
    }
  }

  // ============================================================
  //  ERROR OVERLAY
  // ============================================================
  function showError(title, msg) {
    document.getElementById('errorTitle').textContent = title;
    document.getElementById('errorMsg').textContent = msg;
    document.getElementById('errorOverlay').className = 'error-overlay show';
  }

  function hideError() {
    document.getElementById('errorOverlay').className = 'error-overlay';
  }

  // ============================================================
  //  INIT
  // ============================================================
  findGTASA();
  checkServerStatus();
  setInterval(function() { checkServerStatus(); }, 30000);

</script>

</body>
</html>
