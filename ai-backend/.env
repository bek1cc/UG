# ===== UG AI Developer Panel v2 - Configuration =====
# API key za Z.AI - NIKAD ne dijeli ovo!
ZAI_API_KEY=your-z-ai-api-key-here

# Z.AI API endpoint (OpenAI-compatible)
ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# Model
ZAI_MODEL=glm-5.1

# Backend port
PORT=3777

# Putanja do projekta (SA:MP server root)
PROJECT_ROOT=

# Putanja do Pawn compilera
PAWN_COMPILER=/tmp/pawncc

# Putanja do gamemode fajla
GAMEMODE_PATH=gamemodes/fg-ogc.pwn

# Admin lozinka (za CEF panel auth)
ADMIN_PASSWORD=ug-admin-2024

# RCON za GMX/restart (opcionalno - ako nije set, koristi file-based signal)
RCON_PASSWORD=
RCON_HOST=127.0.0.1
RCON_PORT=7777

# Max backup depth
MAX_BACKUPS=50
