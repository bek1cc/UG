# --- Compiled ---
gamemodes/*.amx
filterscripts/*.amx
*.amx

# --- Logs ---
*.log
log.txt

# --- OS junk ---
Thumbs.db
.DS_Store
desktop.ini

# --- Node ---
node_modules/

# --- Player data (server-generated, keep structure) ---
scriptfiles/Igraci/*
!scriptfiles/Igraci/.gitkeep
scriptfiles/Korisnici/*
!scriptfiles/Korisnici/.gitkeep
scriptfiles/Streljane/*
!scriptfiles/Streljane/.gitkeep
scriptfiles/Admini/*
!scriptfiles/Admini/.gitkeep
scriptfiles/Admins/*
!scriptfiles/Admins/.gitkeep
scriptfiles/Helperi/*
!scriptfiles/Helperi/.gitkeep
scriptfiles/Multiacc/*
!scriptfiles/Multiacc/.gitkeep

# --- Temp / Build ---
upload/
skills/
Deploy/

# --- Removed tools (not needed for running mod) ---
Launcher/
launcher/
ai-backend/
Models/
pawno/
compile_*.txt
compile.bat
ensure-backend.sh
generate_manifest.ps1
open-cef-ports.bat
patch_yhooks.ps1
start.sh
fg-ogc.xml
UnicateGamingLauncher.exe

